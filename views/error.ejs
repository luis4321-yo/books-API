<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Error - Books & Prices</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header>
    <h1><a href="/" class="header-link">Books &amp; Prices</a></h1>
  </header>

  <main>
    <div class="error-state">
      <h2>Something went wrong</h2>
      <p class="error-message"><%= message %></p>

      <div class="error-actions">
        <% if (canRetry && query) { %>
          <a href="/search?q=<%= encodeURIComponent(query) %>" class="btn">Retry search</a>
        <% } %>
        <a href="/" class="btn btn-secondary">Back to home</a>
      </div>
    </div>
  </main>
</body>
</html>
